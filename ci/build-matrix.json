{
  "_comment": "Single source of truth for the release build matrix (CUDA x PyTorch x Python). pytorch_compatibility mirrors PyTorch's official Release Compatibility Matrix and gates which (cuda, torch, python) triples are allowed; enforced by `python scripts/release_matrix.py validate`. Consumers resolve the compound group id `<target>-torch<compact>` (e.g. cu126-torch280) via scripts/release_matrix.py; the publish.yml build matrix is generated by `gen-matrix`. CUDA targets currently still consume sameli/manylinux-cuda images until project-owned GHCR builder image digests are built and verified; builder_images defines wheel-builder image specs used by `gen-wheel-builder-matrix`. A target may set `gcc_toolset` (e.g. cu126 needs GCC 13 because CUDA 12.6 rejects GCC 14).",
  "pytorch_compatibility": {
    "2.4.1": { "python": ["3.8", "3.9", "3.10", "3.11", "3.12"], "cuda_stable": ["11.8", "12.1"] },
    "2.8.0": { "python": ["3.9", "3.10", "3.11", "3.12", "3.13"], "cuda_stable": ["12.6", "12.8"] },
    "2.11.0": { "python": ["3.10", "3.11", "3.12", "3.13", "3.14"], "cuda_stable": ["12.6", "12.8", "13.0"] },
    "2.12.0": { "python": ["3.10", "3.11", "3.12", "3.13", "3.14"], "cuda_stable": ["12.6", "13.0"] }
  },
